<script>
    const CHAVE_PIX = "c90dcbdd-b4a2-4865-b91d-829e467f199a";
    const SEU_WHATSAPP = "47989151965"; // Coloque seu número com DDD aqui!

    function finalizarCompra(produto, valor) {
        // Copia a chave Pix automaticamente
        navigator.clipboard.writeText(CHAVE_PIX).then(() => {
            alert("Aqui está a chave Pix, finalize a compra!\n\nA chave Pix foi copiada para sua área de transferência.");
            
            // Redireciona para o WhatsApp com mensagem pronta
            const mensagem = encodeURIComponent(`Olá! Quero comprar a ${produto} por R$ ${valor}. Já copiei a chave Pix!`);
            window.location.href = `https://wa.me/qr/GGSCLTXVI55PJ1?text=${mensagem}`;
        });
    }
</script>
